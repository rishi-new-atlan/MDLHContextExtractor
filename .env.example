# MDLH Context Extractor — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Your Atlan tenant URL (e.g. mycompany.atlan.com)
ATLAN_TENANT=

# MDLH OAuth client credentials (from Atlan admin console)
MDLH_CLIENT_ID=
MDLH_CLIENT_SECRET=

# API keys for AI-powered context generation (optional)
ANTHROPIC_API_KEY=
OPEN_AI_KEY=
